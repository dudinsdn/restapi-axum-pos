# Required — the app panics on startup if this is missing. There is no
# in-memory fallback: Postgres is the only backend.
#
# The same DATABASE_URL is also used by `cargo test` (via #[sqlx::test]),
# which creates and drops an isolated, migrated database PER TEST under
# this connection. The DB user therefore needs CREATEDB privilege — the
# default `postgres` superuser has this; a restricted app-only user
# usually won't.
DATABASE_URL=postgres://postgres:pg123@localhost:5432/restapi_axum_pos
JWT_SECRET=secret-12345
